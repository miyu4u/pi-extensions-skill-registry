{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"declaration": false,
		"noEmit": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"lib": ["ES2022", "DOM"],
		"types": ["node", "bun-types"],
		"ignoreDeprecations": "6.0",
		"rootDir": "."
	},
	"include": ["src/**/*.ts", "__test__/**/*.ts"]
}
